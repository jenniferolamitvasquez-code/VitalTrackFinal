{
  "framework": "vite",
  "installCommand": "corepack enable && corepack pnpm install --frozen-lockfile",
  "buildCommand": "corepack pnpm --filter @workspace/vital-track build",
  "outputDirectory": "frontend/dist/public",
  "rewrites": [
    {
      "source": "/((?!api/.*).*)",
      "destination": "/index.html"
    }
  ]
}
